# Copy these values into your shell environment or use scripts/aws-connect.sh.
# Do not put AWS secret keys in this file.

ENVIRONMENT=dev
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
AWS_STS_REGIONAL_ENDPOINTS=regional

# Optional when you use a named local AWS profile.
# AWS_PROFILE=pipelineforge-dev

# Created by scripts/aws-connect.sh, or set to an existing private S3 bucket.
TEMPLATE_BUCKET=pipelineforge-templates-123456789012-us-east-1

# Optional ACM certificate for HTTPS on the public ALB.
# CERTIFICATE_ARN=arn:aws:acm:us-east-1:123456789012:certificate/00000000-0000-0000-0000-000000000000
